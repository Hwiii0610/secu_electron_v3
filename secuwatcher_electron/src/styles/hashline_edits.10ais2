/* 호버 시간 툴팁 */
.fcb-hover-tooltip {
  position: absolute;
  bottom: -2px;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.85);
  color: #ffffff;
  font-size: 10px;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: 3px;
  pointer-events: none;
  z-index: 15;
  white-space: nowrap;
  line-height: 1.3;
}
