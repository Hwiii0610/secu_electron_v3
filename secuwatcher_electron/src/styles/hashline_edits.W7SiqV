insert_after 76:f6
  /* Floating & Sidebar z-index */
  --z-sidebar: 30;
  --z-contextbar: 25;
  --z-floating-controls: 50;
  --z-floating-tool-panel: 55;

  /* Floating transitions */
  --transition-floating: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --transition-panel: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
